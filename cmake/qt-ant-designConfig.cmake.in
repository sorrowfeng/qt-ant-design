@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(QT_ANT_DESIGN_QT_MAJOR_VERSION @QT_ANT_DESIGN_QT_MAJOR_VERSION@)
set(QT_ANT_DESIGN_VERSION "@PROJECT_VERSION@")
if(DEFINED QT_VERSION_MAJOR AND NOT QT_VERSION_MAJOR STREQUAL QT_ANT_DESIGN_QT_MAJOR_VERSION)
    message(FATAL_ERROR "qt-ant-design was built with Qt${QT_ANT_DESIGN_QT_MAJOR_VERSION}, but Qt${QT_VERSION_MAJOR} was already found")
endif()
find_dependency(Qt${QT_ANT_DESIGN_QT_MAJOR_VERSION} REQUIRED COMPONENTS Core Widgets Svg)
set(QT_VERSION_MAJOR ${QT_ANT_DESIGN_QT_MAJOR_VERSION})

include("${CMAKE_CURRENT_LIST_DIR}/qt-ant-design-targets.cmake")

check_required_components(qt-ant-design)
